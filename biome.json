{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "off"
			},
			"style": {
				"useImportType": "off"
			}
		}
	},
	"organizeImports": {
		"enabled": true
	},
	"files": {
		"include": ["extensions/**/*.ts", "tests/**/*.ts"],
		"ignore": ["node_modules", ".pi"]
	}
}
